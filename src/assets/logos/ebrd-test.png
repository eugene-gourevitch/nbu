<script>
    (function () {
        console.log(" Target Event Debugger + Motion Cleanup INIT");

        // --- helper: motion cleanup ---
        function cleanupMotionClasses() {
            console.log("cleanupMotionClasses() called");
            var $ = window.jQuery || window.$;

            if (!$) {
                console.warn("jQuery not available, cannot remove motion classes");
                return;
            }

            $('.hidden-fadeIn, .slide-hidden').removeClass('hidden-fadeIn slide-hidden');
            console.log(" Motion classes removed");
        }

        // --- 1) Run once for default/non-Target content ---
        function runInitialCleanup() {
            console.log(" Running initial cleanup for default content");
            cleanupMotionClasses();
        }

        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", function () {
                console.log(" DOMContentLoaded → initial cleanup");
                runInitialCleanup();
            });
        } else {
            // DOM already ready
            runInitialCleanup();
        }

        // --- 2) Register all Adobe Target events by NAME (no adobe.target dependency) ---
        const targetEvents = [
            "at-library-loaded",
            "at-request-start",
            "at-request-succeeded",
            "at-request-failed",
            "at-content-rendering-start",
            "at-content-rendering-succeeded",
            "at-content-rendering-failed",
            "at-content-rendering-redirect",
            "at-content-rendering-no-offers"
        ];

        console.log("Registering Adobe Target event listeners…");

        targetEvents.forEach(function (evtName) {
            document.addEventListener(evtName, function (e) {
                console.log("Adobe Target event fired →", evtName);
                console.log("Event detail:", e && e.detail ? e.detail : e);

                if (evtName === "at-content-rendering-succeeded") {
                    console.log("at-content-rendering-succeeded → running cleanupMotionClasses()");
                    cleanupMotionClasses();
                }
            });
        });
    })();

</script>
    

    

    

<script type="text/javascript">
    CQ_Analytics.TestTarget.maxProfileParams = 11;

    if (CQ_Analytics.CCM) {
        if (CQ_Analytics.CCM.areStoresInitialized) {
            CQ_Analytics.TestTarget.registerMboxUpdateCalls();
        } else {
            CQ_Analytics.CCM.addListener("storesinitialize", function (e) {
                CQ_Analytics.TestTarget.registerMboxUpdateCalls();
            });
        }
    } else {
        // client context not there, still register calls
        CQ_Analytics.TestTarget.registerMboxUpdateCalls();
    }
    </script>
    

    



    
    

        
