        <script>
            window.adobeDataLayer = window.adobeDataLayer || [];

            const pageData = {"event":"pageLoad","page":{"pageName":"404-error","pageType":"","pageURL":"https://www.ebrd.com/content/ebrd_dxp/uk/en/404-error.html","siteSection":"","devicetype":"","language":"en","cookieConsent":"y","reportSuitId":"ebrdproduction","errorPageName":"","country":"global","environment":"PROD"},"user":{"userId":"","userType":"","loginStatus":"","loginDate|Day|Time":""}};
            pageData.page.devicetype = getDeviceType();

            window.adobeDataLayer.push({
                'event': 'pageLoad',
                'component': 'page',
                 pageData
            });

              function getDeviceType() {
                const ua = navigator.userAgent.toLowerCase();
                const width = window.innerWidth;
                const height = window.innerHeight;

                let deviceType = "";

                if (/mobile|android|kindle|silk|fennec|blackberry|bb10|opera mini|opera mobi|iemobile|windows phone/i.test(ua)) {
                    deviceType = "mobile";
                } else if (/ipad|tablet|playbook|silk|touch|nexus 7|nexus 10|galaxy tab|kindle fire|kftt|kfjwa|kfthwi|kfthwa|kfapwi|kfapwa|kfme|sm-t|tablet|xoom|transformer|shield|z180|sc-01c|sc-02c|gt-p|gt-n|shw-m/i.test(ua) || (width <= 1024 && height <= 1366 && width >= 600)) {
                    deviceType = "tablet";
                } else {
                    deviceType = "desktop";
                }

                return deviceType;
            }


        </script>
        <script>
            window.adobeDataLayer = window.adobeDataLayer || [];
            function handleError(statusCode, errorDescription, errorUrl) {
               if (statusCode !== 200) {
                    window.adobeDataLayer.push({
                        'event': 'errorType',
                        'component': 'errorType',
                        'errorinfo': [
                            {
                                'errorType': statusCode,
                                'errorDescription': errorDescription,
                                'errorUrl': errorUrl,
                                'errorTimestamp': new Date().toISOString()
                            }
                        ]
                    });
                }
            }
            fetch(window.location.href)
              .then(response => {
                if (response.status !== 200) {
                    handleError(response.status, 'Error fetching the page', window.location.href);
                }
              })
              .catch(error => {
                console.error('Error fetching the page:', error);
                handleError(500, error.message, window.location.href); // Assuming 500 for fetch errors
              });
        </script>
    


	
